# ─── EDL Dental Lab — Backend Environment Template ───────────────────────────
# Copy this file to .env and fill in real values before running the server.
# NEVER commit .env to source control.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
LOG_LEVEL=info

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# For Docker Compose, use the service name: postgres
DATABASE_URL="postgresql://edl_user:CHANGE_ME@postgres:5432/edl_db?schema=public"

# ── JWT Secrets ───────────────────────────────────────────────────────────────
# Generate strong random values in production:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX_DIFFERENT

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origin domains (no trailing slashes)
CORS_ORIGINS=https://your-frontend-domain.com,https://admin.your-domain.com

# ── Gemini AI ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── AWS S3 (File Upload) ──────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=eu-west-1
S3_BUCKET_NAME=edl-dental-scans
